library(tidyverse)
library(lubridate)
library(janitor)
# ---- 1) Load ----
crime <- readr::read_csv(
"Crime_Data_from_2020_to_2023_20260305.csv",
show_col_types = FALSE
) %>%
janitor::clean_names()
# ---- 2) Main Cleaning ----
crime <- crime %>%
mutate(
# parse dates
date_occ = parse_date_time(
date_occ,
orders = c("ymd HMS", "ymd HM", "ymd", "mdy HMS", "mdy HM", "mdy")
),
date_rptd = parse_date_time(
date_rptd,
orders = c("ymd HMS", "ymd HM", "ymd", "mdy HMS", "mdy HM", "mdy")
),
# keep time_occ as a string, but do NOT standardize blindly
time_occ = as.character(time_occ),
# mark invalid times as NA
time_occ = if_else(str_detect(time_occ, "^\\d{4}$"), time_occ, NA_character_),
# handle 2400 if present
time_occ = if_else(time_occ == "2400", "0000", time_occ),
# extract hour/minute from valid 4-digit times
hour = if_else(is.na(time_occ), NA_integer_, as.integer(str_sub(time_occ, 1, 2))),
minute = if_else(is.na(time_occ), NA_integer_, as.integer(str_sub(time_occ, 3, 4))),
# combine DATE OCC with TIME OCC into a single datetime column
date_occ = if_else(
!is.na(date_occ) & !is.na(hour) & !is.na(minute),
update(date_occ, hours = hour, minutes = minute, seconds = 0),
as.POSIXct(NA)
),
# date-based features
date = as_date(date_occ),
year = year(date_occ),
month = month(date_occ),
month_name = month(date_occ, label = TRUE, abbr = TRUE),
weekday = wday(date_occ, label = TRUE, abbr = TRUE),
# time-of-day bins
time_bin = cut(
hour,
breaks = c(0, 6, 12, 18, 24),
labels = c("Night", "Morning", "Afternoon", "Evening"),
include.lowest = TRUE,
right = FALSE
),
# victim age cleaning
vict_age = if_else(vict_age <= 0, NA_real_, as.numeric(vict_age)),
# basic cleanup for victim fields
vict_sex = na_if(vict_sex, ""),
vict_descent = na_if(vict_descent, ""),
# invalid coordinates to NA
lat = if_else(lat == 0, NA_real_, as.numeric(lat)),
lon = if_else(lon == 0, NA_real_, as.numeric(lon)),
# broad crime category
crime_category = case_when(
str_detect(crm_cd_desc, "ASSAULT|ROBBERY|BATTERY|RAPE|HOMICIDE") ~ "Violent",
TRUE ~ "Property/Other"
),
# simple victim-specific rule:
# crimes like vandalism, burglary, vehicle theft, shoplifting, identity theft
# often do not have one directly observed individual victim in the same sense
has_specific_victim = case_when(
str_detect(
crm_cd_desc,
"ASSAULT|BATTERY|ROBBERY|RAPE|SEX|CHILD|INTIMATE PARTNER|KIDNAPPING|HUMAN TRAFFICKING|CRIMINAL THREATS"
) ~ TRUE,
TRUE ~ FALSE
),
# if NOT a specific-victim crime, mark victim fields as not applicable
vict_sex = if_else(!has_specific_victim, "X", coalesce(vict_sex, "X")),
vict_descent = if_else(!has_specific_victim, "X", coalesce(vict_descent, "X")),
vict_age = if_else(!has_specific_victim, NA_real_, vict_age),
# weapon flag
weapon_present = !is.na(weapon_desc)
)
# ---- 3) Mo Codes ----
mo_lookup <- read_csv(
"mo_codes_lookup.csv",
show_col_types = FALSE
)
# split multiple mocodes into long format and join descriptions
crime_mo_long <- crime %>%
filter(!is.na(mocodes), mocodes != "") %>%
mutate(mo_code = str_extract_all(mocodes, "\\d{4}")) %>%
unnest(mo_code) %>%
left_join(mo_lookup, by = "mo_code")
# collapse MO descriptions back to one row per DR_NO
crime_mo_summary <- crime_mo_long %>%
group_by(dr_no) %>%
summarise(
mo_description = paste(unique(na.omit(description)), collapse = " | "),
is_gang_related = any(mo_code == "0906"),
is_domestic_violence = any(mo_code == "2000"),
is_vehicle_related = any(str_detect(mo_code, "^13")),
is_social_media_related = any(mo_code %in% c("2040", "2041")),
.groups = "drop"
)
# join MO summaries back to main crime data
crime <- crime %>%
left_join(crime_mo_summary, by = "dr_no") %>%
mutate(
is_gang_related = replace_na(is_gang_related, FALSE),
is_domestic_violence = replace_na(is_domestic_violence, FALSE),
is_vehicle_related = replace_na(is_vehicle_related, FALSE),
is_social_media_related = replace_na(is_social_media_related, FALSE)
)
# ---- 4) Sanity checks ----
cat("Rows:", nrow(crime), "\n")
cat("Cols:", ncol(crime), "\n")
crime %>%
summarise(
min_date = min(date_occ, na.rm = TRUE),
max_date = max(date_occ, na.rm = TRUE),
missing_date_occ = sum(is.na(date_occ)),
missing_hour = sum(is.na(hour)),
missing_lat = sum(is.na(lat)),
missing_lon = sum(is.na(lon))
) %>%
print()
crime %>%
summarise(across(everything(), ~ sum(is.na(.)))) %>%
pivot_longer(everything(), names_to = "column", values_to = "n_missing") %>%
mutate(pct_missing = n_missing / nrow(crime)) %>%
arrange(desc(n_missing)) %>%
slice_head(n = 15) %>%
print(n = 15)
library(tidyverse)
library(scales)
library(broom)
crime <- crime %>%
mutate(
time_period = case_when(
year %in% c(2020, 2021) ~ "COVID",
year %in% c(2022, 2023) ~ "Post-COVID",
TRUE ~ NA_character_
)
)
# classify crimes into violent vs property
crime_rq3 <- crime %>%
mutate(
composition_type = case_when(
str_detect(
str_to_upper(crm_cd_desc),
"HOMICIDE|MURDER|MANSLAUGHTER|ROBBERY|ASSAULT|BATTERY|RAPE|SEX|SODOMY|LEWD|KIDNAPPING|HUMAN TRAFFICKING|CRIMINAL THREATS|INTIMATE PARTNER|CHILD ABUSE"
) ~ "Violent",
str_detect(
str_to_upper(crm_cd_desc),
"BURGLARY|THEFT|SHOPLIFTING|LARCENY|STOLEN|VEHICLE|VANDALISM|ARSON|EMBEZZLEMENT|FRAUD|FORGERY|BUNCO|TRESPASS|RECEIVING STOLEN PROPERTY"
) ~ "Property",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(time_period), !is.na(composition_type)) %>%
mutate(
time_period = factor(time_period, levels = c("COVID", "Post-COVID")),
composition_type = factor(composition_type, levels = c("Violent", "Property"))
)
rq3_summary <- crime_rq3 %>%
count(time_period, composition_type) %>%
group_by(time_period) %>%
mutate(
proportion = n / sum(n)
) %>%
ungroup()
rq3_summary
# proportions plot
ggplot(rq3_summary, aes(x = time_period, y = proportion, fill = composition_type)) +
geom_col(position = "fill") +
scale_y_continuous(labels = percent_format()) +
labs(
title = "Crime Composition During and After COVID-19",
subtitle = "Proportion of violent and property crimes in Los Angeles",
x = "Time Period",
y = "Proportion of Crimes",
fill = "Crime Type"
) +
theme_minimal()
# count plot
ggplot(rq3_summary, aes(x = time_period, y = n, fill = composition_type)) +
geom_col(position = "dodge") +
labs(
title = "Counts of Violent and Property Crimes by Time Period",
x = "Time Period",
y = "Number of Crimes",
fill = "Crime Type"
) +
theme_minimal()
# contingency table
rq3_table <- table(crime_rq3$time_period, crime_rq3$composition_type)
rq3_table
# chi-square test
rq3_chisq <- chisq.test(rq3_table)
rq3_chisq
rq3_chisq$stdres
# proportion test for violent crime share
violent_counts <- crime_rq3 %>%
group_by(time_period) %>%
summarise(
violent_n = sum(composition_type == "Violent"),
total_n = n(),
violent_prop = violent_n / total_n,
.groups = "drop"
)
violent_counts
rq3_prop <- prop.test(
x = violent_counts$violent_n,
n = violent_counts$total_n
)
rq3_prop
tidy(rq3_chisq)
tidy(rq3_prop)
# year-by-year composition plot
rq3_yearly <- crime_rq3 %>%
count(year, composition_type) %>%
group_by(year) %>%
mutate(proportion = n / sum(n)) %>%
ungroup()
ggplot(rq3_yearly, aes(x = factor(year), y = proportion, fill = composition_type)) +
geom_col(position = "fill") +
scale_y_continuous(labels = percent_format()) +
labs(
title = "Year-by-Year Crime Composition, 2020 to 2023",
x = "Year",
y = "Proportion of Crimes",
fill = "Crime Type"
) +
theme_minimal()
